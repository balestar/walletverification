    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "eslint": "8.57.1",
    "eslint-config-next": "16.2.6",
    "postcss": "^8",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "wrangler": "^4.94.0"
  }
